@echo off
:loop
powershell -command "$wsh = New-Object -ComObject WScript.Shell; Add-Type -AssemblyName System.Windows.Forms; $orig = [System.Windows.Forms.Cursor]::Position; $wsh.SendKeys('{SCROLLLOCK}'); $points = @( @(10,0), @(10,10), @(0,10), @(0,0) ); foreach($d in $points) { [System.Windows.Forms.Cursor]::Position = New-Object System.Drawing.Point($orig.X + $d[0], $orig.Y + $d[1]); Sleep -Milliseconds 300 }; [System.Windows.Forms.Cursor]::Position = $orig"
timeout /t 300 /nobreak >nul
goto loop
