    return render_template_string(CLIENT_PAGE, 
                                  prefix=COMPUTER_PREFIX)

@app.route('/admin')
def admin_page():
    """Админ-панель с логом"""
    stats = {
        'total': len(call_log),
        'success': sum(1 for c in call_log if c['status'] == 'ok'),
        'failed': sum(1 for c in call_log if c['status'] == 'error')
    }
    return render_template_string(ADMIN_PAGE,
                                  ip=LOCAL_IP,
                                  prefix=COMPUTER_PREFIX,
                                  call_log=call_log,
                                  stats=stats)

@app.route('/api/call', methods=['POST'])
def make_call():
    """Вызов специалиста"""
    data = request.json
    pc_number = data.get('pc')
    message_text = data.get('message', '').strip()
    
    if not pc_number or pc_number < 1 or pc_number > COMPUTER_COUNT:
        return jsonify({'status': 'error', 'message': f'Неверный номер (1-{COMPUTER_COUNT})'})
    
    pc_name = f"{COMPUTER_PREFIX}{pc_number:02d}"
    return send_msg(pc_name, message_text)

def send_msg(pc_name, message_text):
    """Отправка сообщения через msg"""
    # Формируем сообщение
    if message_text:
        full_message = f"ВНИМАНИЕ! Подойдите в обработку\n\nСообщение: {message_text}"
    else:
        full_message = "ВНИМАНИЕ! Подойдите в обработку"
    
    # Экранируем кавычки для cmd
    full_message = full_message.replace('"', '\\"')
    
    command = f'msg * /server:{pc_name} "{full_message}"'
    
    try:
        result = subprocess.run(
            command,
            shell=True,
            capture_output=True,
            text=True,
            timeout=5
        )
        
        if result.returncode == 0:
            success = True
            msg = f"Сообщение отправлено на {pc_name}"
        else:
            success = False
            error = result.stderr.strip() or 'Неизвестная ошибка'
            msg = f"Ошибка: {error}"
            
    except subprocess.TimeoutExpired:
        success = False
        msg = f"Таймаут: {pc_name} не отвечает"
    except Exception as e:
        success = False
        msg = f"Ошибка: {str(e)}"
    
    # Логируем вызов
    call_log.append({
        'time': datetime.now().strftime('%H:%M:%S'),
        'pc': pc_name,
        'text': message_text if message_text else None,
        'status': 'ok' if success else 'error',
        'message': msg
    })
    
    return jsonify({'status': 'ok' if success else 'error', 'message': msg})

