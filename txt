import pyautogui
import math
import time

# Настройки безопасности — двигаем мышь плавно
pyautogui.FAILSAFE = True  # Дёрнешь мышь в угол экрана — скрипт остановится
pyautogui.PAUSE = 0.01     # Пауза между движениями

def draw_star(center_x, center_y, size=80):
    """Рисует пятиконечную звезду."""
    points = []
    for i in range(5):
        # Внешняя точка
        angle = math.radians(-90 + i * 72)
        x = center_x + size * math.cos(angle)
        y = center_y + size * math.sin(angle)
        points.append((x, y))
        
        # Внутренняя точка
        angle = math.radians(-90 + i * 72 + 36)
        x = center_x + size * 0.38 * math.cos(angle)
        y = center_y + size * 0.38 * math.sin(angle)
        points.append((x, y))
    
    # Перемещаемся к первой точке
    pyautogui.moveTo(points[0][0], points[0][1], duration=0.2)
    # Рисуем звезду
    for point in points[1:]:
        pyautogui.moveTo(point[0], point[1], duration=0.15)
    # Замыкаем
    pyautogui.moveTo(points[0][0], points[0][1], duration=0.15)

def draw_circle(center_x, center_y, radius=70):
    """Рисует круг."""
    pyautogui.moveTo(center_x + radius, center_y, duration=0.2)
    for angle in range(0, 361, 10):
        rad = math.radians(angle)
        x = center_x + radius * math.cos(rad)
        y = center_y + radius * math.sin(rad)
        pyautogui.moveTo(x, y, duration=0.02)

print("🖱️ Скрипт запущен. Мышь будет рисовать звёздочку и круг.")
print("⚠️ Чтобы остановить — дёрни мышь в угол экрана (CTRL+C тоже работает).")
print("-" * 50)

try:
    while True:
        # Определяем центр экрана
        screen_width, screen_height = pyautogui.size()
        cx, cy = screen_width // 2, screen_height // 2
        
        # Немного смещаем центр для разнообразия
        import random
        cx += random.randint(-100, 100)
        cy += random.randint(-100, 100)
        
        draw_star(cx, cy, size=60)
        time.sleep(0.3)
        draw_circle(cx, cy, radius=60)
        time.sleep(0.5)
        
except KeyboardInterrupt:
    print("\n✅ Скрипт остановлен.")
